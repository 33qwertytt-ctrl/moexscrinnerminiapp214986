# BondScreener MOEX example environment.
# Keep real secrets only in your local `.env` or OS environment variables.

BONDS_MIN_RATING=ruA
BONDS_DEFAULT_HORIZON=30
BONDS_LIMIT=20
BONDS_LOG_LEVEL=INFO
BONDS_CACHE_TTL=3600
BONDS_CACHE_DIR=./.cache

BONDS_PUBLIC_DOMAIN=moextab.duckdns.org
BONDS_PUBLIC_IPV4=
BONDS_PUBLIC_IPV6=
BONDS_ALLOWED_HOSTS=

BONDS_TELEGRAM_MINIAPP_BOT_TOKEN=
BONDS_TELEGRAM_FEEDBACK_BOT_TOKEN=
BONDS_TELEGRAM_FEEDBACK_BOT_USERNAME=
BONDS_TELEGRAM_FEEDBACK_WEBHOOK_SECRET=
BONDS_TELEGRAM_INIT_DATA_TTL_SECONDS=86400
BONDS_FEEDBACK_ADMIN_TELEGRAM_IDS=
BONDS_FEEDBACK_NOTIFY_CHAT_IDS=

BONDS_FEEDBACK_DB_PATH=./data/feedback.db
BONDS_FEEDBACK_UPLOAD_DIR=./data/feedback_uploads
BONDS_FEEDBACK_MAX_ATTACHMENT_BYTES=26214400
BONDS_FEEDBACK_MAX_MESSAGE_CHARS=4000
BONDS_FEEDBACK_ALLOWED_MIME_TYPES=image/png,image/jpeg,image/webp,application/pdf,text/plain,text/csv,application/json
BONDS_FEEDBACK_ALLOWED_EXTENSIONS=png,jpg,jpeg,webp,pdf,txt,log,csv,json
BONDS_FEEDBACK_PAIRING_CODE_TTL_MINUTES=30
BONDS_FEEDBACK_PAIRING_CODE_LENGTH=8
BONDS_FEEDBACK_PAIRING_CODE_ALPHABET=
BONDS_FEEDBACK_ARCHIVE_REPLY_LIMIT=25

BONDS_API_BONDS_RATE_LIMIT_PER_MINUTE=60
BONDS_FEEDBACK_SUBMIT_RATE_LIMIT_PER_MINUTE=10
BONDS_FEEDBACK_PAIR_RATE_LIMIT_PER_MINUTE=10
BONDS_FEEDBACK_WEBHOOK_MAX_BODY_BYTES=262144
